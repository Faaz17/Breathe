{
  "name": "breathe-extension",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Breathe — privacy-first, local meeting notes browser extension (MV3).",
  "scripts": {
    "dev": "vite",
    "build": "node scripts/copy-ort.mjs && tsc -b && vite build && vite build --config vite.content.config.ts && node scripts/trim-dist.mjs",
    "build:content": "vite build --config vite.content.config.ts",
    "copy-ort": "node scripts/copy-ort.mjs",
    "preview": "vite preview",
    "typecheck": "tsc -b",
    "icons": "node scripts/gen-icons.mjs"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "idb": "^8.0.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.6.1",
    "@tailwindcss/vite": "^4.3.1",
    "@types/chrome": "^0.1.43",
    "@types/node": "^22.0.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.2.0",
    "tailwindcss": "^4.3.1",
    "typescript": "^5.9.0",
    "vite": "^7.3.5"
  }
}
